---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { projectRegistry } from '../../../projects/registry';
import { MasonryCalculator } from './MasonryCalculator';

const project = projectRegistry.find(p => p.id === 'masonry-wall');
const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title={project?.title || "Masonry Wall"} description={project?.blurb}>
  <Fragment slot="breadcrumb">
    <a href={baseUrl}>Home</a><span>/</span><span class="current">{project?.title}</span>
  </Fragment>

  <div class="max-w-3xl">
    <h1 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">{project?.title}</h1>
    <p class="text-lg text-text-muted mb-8">{project?.blurb}</p>

    <MasonryCalculator client:load />

    <p class="text-sm text-text-muted mt-8">
      Estimates use standard coverage rates (51 bricks/m², 10 blocks/m²) and round
      up to whole packs. Always confirm quantities with a trade professional.
    </p>
  </div>
</BaseLayout>
