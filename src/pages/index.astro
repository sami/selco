---
const BASE_URL = import.meta.env.BASE_URL;
const title = "Trade Materials Calculators";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-gray-900 p-8">
    <main class="max-w-4xl mx-auto space-y-6">
      <h1 class="text-4xl font-bold text-[#04204b]">{title}</h1>
      <p class="text-lg">Placeholder site for the 1 Jul reset.</p>
    </main>
  </body>
</html>
