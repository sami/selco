---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projectRegistry } from '../projects/registry';

const baseUrl = import.meta.env.BASE_URL;
const getUrl = (route: string) => {
  const base = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;
  return `${base}${route}`;
};

const projectCalculators = projectRegistry.filter(p => p.category === 'Project Calculators');

/** Concept-style presentation for each registry entry. */
const cardMeta: Record<string, { icon: string; tagline: string }> = {
  'masonry-wall': {
    icon: 'fa-trowel-bricks',
    tagline: 'Bricks, mortar, sand and wall ties, pack-rounded',
  },
  'hard-flooring': {
    icon: 'fa-table-cells-large',
    tagline: 'Packs, underlay and trims counted together',
  },
};

const valueBlocks = [
  {
    icon: 'fa-pencil',
    title: 'Guided flow',
    copy: 'Answer one question at a time — dimensions in, materials out. No coverage tables, no formula sheet, no working it out on a fag packet at the counter.',
  },
  {
    icon: 'fa-receipt',
    title: 'A list you can hand over',
    copy: 'Every calculator finishes with a materials list rounded up to whole bags and boxes of products we actually stock. Read it out at the trade counter as-is.',
  },
  {
    icon: 'fa-toolbox',
    title: 'The bits everyone forgets',
    copy: 'Wall ties with the bricks. Underlay with the boards. Wastage already counted, so Saturday doesn’t end with a second trip to the yard.',
  },
];

const steps = [
  { title: 'Pick your job', copy: 'Choose Masonry Wall or Hard Flooring below.' },
  { title: 'Enter measurements', copy: 'Type in the sizes off your tape measure — metres are fine.' },
  { title: 'Get your list', copy: 'A full materials list with wastage included, ready for ordering.' },
];

const seoTitle = "Trade Projects Calculator";
const seoDescription = "Project calculators for tradespeople. Calculate all materials for masonry walls and hard flooring in one guided flow. Accurate quantities with wastage included.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": seoTitle,
  "description": seoDescription,
  "url": "https://sami.github.io/selco/"
};
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <Fragment slot="breadcrumb">
    <a href={baseUrl}>Home</a><span>/</span><span class="current">Project Planner</span>
  </Fragment>

  {/* Hero */}
  <section class="relative overflow-hidden rounded-2xl bg-brand-navy text-white mb-12">
    <div aria-hidden="true" class="absolute inset-0 opacity-[0.08]" style="background-image: linear-gradient(to right, #fff 1px, transparent 1px), linear-gradient(to bottom, #fff 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div aria-hidden="true" class="absolute inset-x-0 top-0 h-1.5" style="background: repeating-linear-gradient(-45deg, #ffd407 0 12px, #04204b 12px 24px);"></div>
    <div class="relative px-6 py-12 md:px-12 md:py-16 max-w-3xl">
      <span class="inline-flex items-center gap-2 rounded-full bg-brand-yellow text-brand-navy px-3 py-1 text-[0.7rem] font-extrabold uppercase tracking-[0.15em] mb-5">
        <i class="fas fa-ruler-combined" aria-hidden="true"></i>
        Project Planner
      </span>
      <h1 class="text-3xl md:text-5xl font-extrabold uppercase tracking-tight leading-[1.05] mb-4" style="font-family: 'Arial Black', sans-serif; letter-spacing: -1px;">
        Measure twice.<br />
        <span class="text-brand-yellow">Order once.</span>
      </h1>
      <p class="text-base md:text-lg text-white/85 leading-relaxed mb-8 max-w-xl">
        Tell us the size of the job and we&#39;ll write your materials list. Sizes, quantities and the bits everyone forgets, ready for the counter.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href={getUrl('/projects/masonry-wall')} class="btn-accent">
          Plan a masonry wall
          <i class="fas fa-arrow-right text-sm" aria-hidden="true"></i>
        </a>
        <a href={getUrl('/projects/hard-flooring')} class="btn-ghost !text-white !border-white hover:!bg-white/10">
          Plan hard flooring
        </a>
      </div>
    </div>
  </section>

  {/* Value blocks */}
  <section class="grid gap-4 sm:grid-cols-3 mb-14">
    {valueBlocks.map(block => (
      <div class="card card-hover">
        <span class="inline-flex items-center justify-center w-11 h-11 rounded-lg bg-brand-yellow text-brand-navy text-lg mb-3">
          <i class={`fas ${block.icon}`} aria-hidden="true"></i>
        </span>
        <h2 class="text-lg font-bold text-text-main mb-1.5">{block.title}</h2>
        <p class="text-sm text-text-muted leading-relaxed m-0">{block.copy}</p>
      </div>
    ))}
  </section>

  {/* Three-step strip */}
  <section class="card mb-14">
    <h2 class="sr-only">How it works</h2>
    <div class="grid gap-6 sm:grid-cols-3">
      {steps.map((step, i) => (
        <div class="flex items-start gap-4">
          <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-brand-navy text-brand-yellow font-extrabold shrink-0" aria-hidden="true">{i + 1}</span>
          <div>
            <p class="font-bold text-text-main mb-1">{step.title}</p>
            <p class="text-sm text-text-muted leading-relaxed m-0">{step.copy}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* Catalogue */}
  <section class="mb-14">
    <div class="mb-8">
      <h2 class="text-2xl md:text-3xl font-bold text-text-main mb-1">Pick your job</h2>
      <p class="text-text-muted text-base m-0">Every list uses products we stock, rounded to whole packs.</p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {projectCalculators.map(calc => (
        <a href={getUrl(calc.route)} class="group card card-hover relative overflow-hidden flex flex-col">
          <div aria-hidden="true" class="absolute inset-x-0 top-0 h-1 opacity-0 group-hover:opacity-100 transition-opacity" style="background: repeating-linear-gradient(-45deg, #ffd407 0 10px, #04204b 10px 20px);"></div>
          <div class="flex items-center gap-3 mb-2">
            <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-brand-navy text-brand-yellow shrink-0">
              <i class={`fas ${cardMeta[calc.id]?.icon ?? 'fa-calculator'}`} aria-hidden="true"></i>
            </span>
            <h3 class="text-base font-bold text-text-main m-0 group-hover:text-primary transition-colors">{calc.title}</h3>
          </div>
          <p class="text-sm text-text-muted leading-relaxed mb-3">{calc.blurb}</p>
          <span class="mt-auto inline-flex items-center gap-2 text-xs font-bold text-primary-nav">
            <i class="fas fa-list-check" aria-hidden="true"></i>
            {cardMeta[calc.id]?.tagline ?? 'Materials list + checklist'}
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
