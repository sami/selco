---
// The live calculators now live under /concept (the Project Planner). Users
// still land on the old root, so send them there. Static-friendly redirect:
// a 0-second meta refresh and a canonical link, with a JS fallback. BASE_URL
// keeps it correct under the /selco subpath in production and in dev.
const BASE_URL = import.meta.env.BASE_URL;
const base = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;
const target = `${base}concept/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <meta name="robots" content="noindex" />
    <title>Trade Materials Calculators</title>
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </head>
  <body>
    <p>Redirecting to the <a href={target}>Trade Materials Calculators</a>…</p>
  </body>
</html>
