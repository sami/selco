---
import SelcoLayout from '../../layouts/SelcoLayout.astro';
import SpecCalculator from '../../components/v2/SpecCalculator';
import { ALL_SPECS } from '../../calculators/v2/specs';

export function getStaticPaths() {
  return ALL_SPECS.map((spec) => ({
    params: { slug: spec.slug },
    props: { name: spec.name, description: spec.description, category: spec.category },
  }));
}

const { slug } = Astro.params;
const { name, description, category } = Astro.props;

const BASE_URL = import.meta.env.BASE_URL;
const base = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;

const breadcrumbs = [
  { label: 'Home', href: base },
  { label: 'Project Planner', href: `${base}concept/` },
  { label: name },
];
---

<SelcoLayout
  title={`${name} | Project Planner`}
  description={description}
  breadcrumbs={breadcrumbs}
  pageTitle={name}
>
  <main class="w-full">
    <p class="text-base text-text-muted max-w-2xl -mt-2 mb-2">
      {description}
    </p>
    <p class="text-xs font-bold uppercase tracking-[0.15em] text-primary-nav mb-8">
      {category}
    </p>

    <SpecCalculator slug={slug} client:load />

    <p class="mt-10 text-sm text-text-muted">
      <a href={`${base}concept/`} class="font-bold text-primary-nav hover:underline">
        ← All planning tools
      </a>
    </p>
  </main>
</SelcoLayout>
