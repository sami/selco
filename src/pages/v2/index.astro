---
import SelcoLayout from '../../layouts/SelcoLayout.astro';
import { V2_CALCULATORS, V2_CATEGORY_ORDER } from '../../components/v2/registry';

const BASE_URL = import.meta.env.BASE_URL;
const base = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;

const breadcrumbs = [
  { label: 'Home', href: base },
  { label: 'Concept Hub v2' },
];

const title = 'Project Hub — v2 concept';
const description =
  'Concept showcase: a new generation of trade materials calculators — live previews, named products, and counter-ready lists for every job.';

const calculatorCount = V2_CALCULATORS.length;

const grouped = V2_CATEGORY_ORDER.map((category) => ({
  category,
  calculators: V2_CALCULATORS.filter((c) => c.category === category),
})).filter((g) => g.calculators.length > 0);

const pillars = [
  {
    icon: 'fa-bolt',
    title: 'Answers as you type',
    body: 'No submit button, no waiting. Every measurement updates the plan and the materials list instantly.',
  },
  {
    icon: 'fa-drafting-compass',
    title: 'See the job, not just numbers',
    body: 'Calculators draw the job — roll strips, slab grids, unit layouts — so customers trust the quantities.',
  },
  {
    icon: 'fa-toolbox',
    title: 'Never caught short',
    body: 'Every list ends with the tools and consumables the job needs — the hinges, the silicone, the FFP3 mask.',
  },
];

---

<SelcoLayout
  title={title}
  description={description}
  breadcrumbs={breadcrumbs}
  pageTitle=""
>
  <main class="w-full">
    {/* Hero */}
    <section class="relative overflow-hidden rounded-2xl bg-brand-navy text-white mb-12">
      <div
        aria-hidden="true"
        class="absolute inset-0 opacity-[0.08]"
        style="background-image: linear-gradient(to right, #fff 1px, transparent 1px), linear-gradient(to bottom, #fff 1px, transparent 1px); background-size: 32px 32px;"
      >
      </div>
      <div
        aria-hidden="true"
        class="absolute inset-x-0 top-0 h-1.5"
        style="background: repeating-linear-gradient(-45deg, #ffd407 0 12px, #04204b 12px 24px);"
      >
      </div>
      <div class="relative px-6 py-12 md:px-12 md:py-16 max-w-3xl">
        <span
          class="inline-flex items-center gap-2 rounded-full bg-brand-yellow text-brand-navy px-3 py-1 text-[0.7rem] font-extrabold uppercase tracking-[0.15em] mb-5"
        >
          <i class="fas fa-flask" aria-hidden="true"></i>
          Concept showcase · v2
        </span>
        <h1
          class="text-3xl md:text-5xl font-extrabold uppercase tracking-tight leading-[1.05] mb-4"
          style="font-family: 'Arial Black', sans-serif; letter-spacing: -1px;"
        >
          {calculatorCount} trades.<br />
          <span class="text-brand-yellow">One counter-ready list</span> each.
        </h1>
        <p class="text-base md:text-lg text-white/85 leading-relaxed mb-8 max-w-xl">
          {description} Built for builders and DIYers planning real jobs — and built to
          show where the calculators can go next.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href={`${base}v2/artificial-grass/`} class="btn-accent">
            Try artificial grass
            <i class="fas fa-arrow-right text-sm" aria-hidden="true"></i>
          </a>
          <a href={`${base}v2/roof-pitched/`} class="btn-ghost !text-white !border-white hover:!bg-white/10">
            Price up a roof
          </a>
        </div>
      </div>
    </section>

    {/* Pillars */}
    <section class="grid gap-4 sm:grid-cols-3 mb-14">
      {pillars.map((p) => (
        <div class="card card-hover">
          <span
            class="inline-flex items-center justify-center w-11 h-11 rounded-lg bg-brand-yellow text-brand-navy text-lg mb-3"
          >
            <i class={`fas ${p.icon}`} aria-hidden="true"></i>
          </span>
          <h2 class="text-lg font-bold text-text-main mb-1.5">{p.title}</h2>
          <p class="text-sm text-text-muted leading-relaxed m-0">{p.body}</p>
        </div>
      ))}
    </section>

    {/* Calculator catalogue, grouped by trade */}
    <section class="mb-14">
      <div class="flex items-end justify-between gap-4 mb-8 flex-wrap">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-text-main mb-1">
            The full catalogue — {calculatorCount} calculators
          </h2>
          <p class="text-text-muted text-base m-0">
            Organised the way the yard is: by trade. Quantities and named products — pricing
            comes when the catalogue is mapped.
          </p>
        </div>
      </div>

      <div class="space-y-10">
        {grouped.map((group) => (
          <div>
            <div class="flex items-center gap-3 mb-4">
              <h3 class="text-lg font-extrabold uppercase tracking-wide text-brand-navy m-0 whitespace-nowrap">
                {group.category}
              </h3>
              <span
                aria-hidden="true"
                class="h-0.5 flex-1"
                style="background: repeating-linear-gradient(-45deg, #ffd407 0 8px, transparent 8px 16px);"
              ></span>
              <span class="text-xs font-bold text-text-muted whitespace-nowrap">
                {group.calculators.length} tools
              </span>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {group.calculators.map((calc) => (
                <a
                  href={`${base}v2/${calc.slug}/`}
                  class="group card card-hover relative overflow-hidden flex flex-col"
                >
                  <div
                    aria-hidden="true"
                    class="absolute inset-x-0 top-0 h-1 opacity-0 group-hover:opacity-100 transition-opacity"
                    style="background: repeating-linear-gradient(-45deg, #ffd407 0 10px, #04204b 10px 20px);"
                  >
                  </div>
                  <div class="flex items-center gap-3 mb-2">
                    <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-brand-navy text-brand-yellow shrink-0">
                      <i class={`fas ${calc.icon}`} aria-hidden="true"></i>
                    </span>
                    <h4 class="text-base font-bold text-text-main m-0 group-hover:text-primary transition-colors">
                      {calc.name}
                    </h4>
                  </div>
                  <p class="text-sm text-text-muted leading-relaxed mb-3">{calc.description}</p>
                  <span class="mt-auto inline-flex items-center gap-2 text-xs font-bold text-primary-nav">
                    <i
                      class={`fas ${calc.kind === 'bespoke' ? 'fa-drafting-compass' : 'fa-list-check'}`}
                      aria-hidden="true"
                    ></i>
                    {calc.kind === 'bespoke' ? calc.preview : 'Materials + tools checklist'}
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* Director pitch strip */}
    <section class="rounded-2xl border-2 border-primary-nav bg-gradient-to-br from-primary-nav/5 to-transparent p-6 md:p-8 mb-6">
      <h2 class="text-xl md:text-2xl font-bold text-text-main mb-4">Why this matters for SELCO</h2>
      <div class="grid gap-5 md:grid-cols-3 text-sm text-text-muted leading-relaxed">
        <p class="m-0">
          <strong class="text-text-main block mb-1">Customers buy with confidence.</strong>
          A visible plan and a complete list means fewer under-orders, fewer second trips, and
          fewer returns at the counter.
        </p>
        <p class="m-0">
          <strong class="text-text-main block mb-1">Every estimate cross-sells.</strong>
          Lists don't stop at the headline product — they add the primer, the silicone, the
          fixings and the consumables customers forget until halfway through the job.
        </p>
        <p class="m-0">
          <strong class="text-text-main block mb-1">Ready for the catalogue.</strong>
          Every line is a named product slot. Map them to live SKUs and pricing, and each list
          becomes a basket.
        </p>
      </div>
      <p class="text-xs text-text-muted mt-6 mb-0 pt-4 border-t border-border-default">
        <i class="fas fa-circle-info mr-1" aria-hidden="true"></i>
        Concept demonstration: quantities are estimates and product names are representative of
        stocked ranges — final mapping to live SKUs and pricing is the next phase.
      </p>
    </section>
  </main>
</SelcoLayout>
