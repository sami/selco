---
import SelcoLayout from '../../../layouts/SelcoLayout.astro';
import PlasterCalculator from '../../../components/v2/PlasterCalculator';
import { V2_CALCULATORS } from '../../../components/v2/registry';

const BASE_URL = import.meta.env.BASE_URL;
const base = BASE_URL.endsWith('/') ? BASE_URL : `${BASE_URL}/`;
const meta = V2_CALCULATORS.find((c) => c.slug === 'plastering')!;

const breadcrumbs = [
  { label: 'Home', href: base },
  { label: 'Concept Hub v2', href: `${base}v2/` },
  { label: meta.name },
];
---

<SelcoLayout
  title={`${meta.name} — v2 concept`}
  description={meta.description}
  breadcrumbs={breadcrumbs}
  pageTitle={meta.name}
>
  <main class="w-full">
    <p class="text-base text-text-muted max-w-2xl -mt-2 mb-8">
      {meta.description}
    </p>

    <PlasterCalculator client:load />

    <p class="mt-10 text-sm text-text-muted">
      <a href={`${base}v2/`} class="font-bold text-primary-nav hover:underline">
        ← All v2 concept calculators
      </a>
    </p>
  </main>
</SelcoLayout>
